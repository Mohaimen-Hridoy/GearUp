meta {
  name: Mark Rental Returned
  type: http
  seq: 13
  tags: [rental, provider]
}

patch {
  url: {{baseUrl}}/rentals/{{rentalOrderId}}
}

headers {
  content-type: application/json
  Authorization: Bearer {{providerToken}}
}

body {
  {
    "status": "RETURNED"
  }
}

tests {
  test("should mark rental as returned", function () {
    expect(res.status).to.equal(200);
    expect(res.body.data.status).to.equal("RETURNED");
  });
}