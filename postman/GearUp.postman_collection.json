    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const start = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();",
                  "const end = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString();",
                  "pm.environment.set(\"rentalStartDate\", start);",
                  "pm.environment.set(\"rentalEndDate\", end);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.environment.set(\"rentalOrderId\", body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"{{gearId}}\",\n  \"startDate\": \"{{rentalStartDate}}\",\n  \"endDate\": \"{{rentalEndDate}}\"\n}"
            },
            "url": {
